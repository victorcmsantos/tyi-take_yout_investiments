# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env (ele esta no .gitignore).

# Market data providers
MARKET_DATA_PROVIDERS=twelve_data,alpha_vantage,brapi,coingecko,google,yahoo
# Opcional: sobrescreve a lista para ativos BR/US/Cripto
# MARKET_DATA_PROVIDERS_BR=market_scanner
# MARKET_DATA_PROVIDERS_US=twelve_data,alpha_vantage,yahoo
# MARKET_DATA_PROVIDERS_CRYPTO=yahoo,coingecko
# Usa os dados BR do market-scanner (banco unico) como fonte principal.
# MARKET_DATA_USE_SCANNER_BR=1
# TTL do cache local para leitura do banco do scanner (segundos).
# MARKET_SCANNER_DATA_TTL_SECONDS=120
# Cache curto de quote do BRAPI (segundos), para evitar bursts no mesmo ciclo.
# BRAPI_QUOTE_CACHE_TTL_SECONDS=120
# Se BRAPI retornar limite/erro temporario, pausa novas tentativas por alguns segundos.
# BRAPI_RATE_LIMIT_COOLDOWN_SECONDS=300
# Se a CoinGecko retornar 429/limite, pausa tentativas por alguns segundos.
# COINGECKO_RATE_LIMIT_COOLDOWN_SECONDS=900
# SLA de staleness por classe (segundos). Se vazio, usa MARKET_DATA_STALE_AFTER_SECONDS.
# MARKET_DATA_STALE_AFTER_SECONDS=43200
# MARKET_DATA_STALE_AFTER_SECONDS_BR=1800
# MARKET_DATA_STALE_AFTER_SECONDS_FIIS=1800
# MARKET_DATA_STALE_AFTER_SECONDS_US=900
# MARKET_DATA_STALE_AFTER_SECONDS_CRYPTO=300
# Orçamento de chamadas por provider (0 = sem limite local).
# BRAPI_CALL_BUDGET_PER_MINUTE=0
# BRAPI_CALL_BUDGET_PER_HOUR=0
# BRAPI_CALL_BUDGET_PER_DAY=0
# COINGECKO_CALL_BUDGET_PER_MINUTE=0
# COINGECKO_CALL_BUDGET_PER_HOUR=0
# COINGECKO_CALL_BUDGET_PER_DAY=0
# Controle do sincronizador de mercado em background.
# MARKET_SYNC_ENABLED=0
# MARKET_SYNC_INTERVAL_SECONDS=300
# MARKET_SYNC_SCOPE=all
# MARKET_SYNC_FORCE_LIVE_BR=0
# Pre-aquecimento da agenda de proventos futuros (startup + intervalo).
# UPCOMING_INCOME_SYNC_ENABLED=1
# UPCOMING_INCOME_SYNC_INTERVAL_SECONDS=1800
# UPCOMING_INCOME_SYNC_WARMUP_ON_STARTUP=1
# UPCOMING_INCOME_SYNC_MAX_ITEMS_PER_TICKER=8
# UPCOMING_INCOME_SYNC_MAX_TICKERS_PER_RUN=0  # 0 = sem limite (todos os tickers da carteira)
# Usa fallback por historico de proventos para preencher agenda quando nao houver anuncio oficial.
# UPCOMING_INCOME_HISTORY_ESTIMATE_ENABLED=1

# Tokens/keys (opcional, depende do provider habilitado)
BRAPI_TOKEN=
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=
COINGECKO_API_KEY=

# Token do Gateway do OpenClaw (necessario para o backend chamar /tools/invoke).
# Dica: ele tambem fica em openclaw/config/openclaw.json (gateway.auth.token).
OPENCLAW_GATEWAY_TOKEN=

# (Opcional) URL do gateway (padrao: https://openclaw-gateway:18789 dentro do compose)
OPENCLAW_GATEWAY_URL=

# (Opcional) imagem do OpenClaw usada por openclaw-gateway/openclaw-cli.
# Padrao no compose: ghcr.io/openclaw/openclaw:latest
OPENCLAW_IMAGE=

# Integracao com Market Scanner (servico opcional via profile "scanner")
MARKET_SCANNER_BASE_URL=http://market-scanner:8000
MARKET_SCANNER_TIMEOUT_SECONDS=8
# Timeout especifico para scan geral manual (pode levar varios minutos).
MARKET_SCANNER_SCAN_TIMEOUT_SECONDS=600
MARKET_SCANNER_PORT=8089
MARKET_SCANNER_DATA_DIR=./market-scanner/data
# Caminho do DB compartilhado entre backend e scanner (banco unico).
MARKET_SCANNER_DATABASE_PATH=/app_vol/investments.db
# URL do DB usada pelo container market-scanner.
MARKET_SCANNER_DATABASE_URL=sqlite:////app_vol/investments.db

# TTL do cache de enriquecimento exibido na pagina do ativo, em dias.
VITE_OPENCLAW_ENRICHMENT_STALE_DAYS=3

# (Opcional) caminhos de volumes no host (default do compose atual usa /srv/...)
# Para rodar em qualquer pasta, use o arquivo docker-compose.portable.yml
# ou sete explicitamente:
APP_VOL_DIR=./app_vol
OPENCLAW_CONFIG_DIR=./openclaw/config
OPENCLAW_WORKSPACE_DIR=./openclaw/workspace

# Opcional (se você usar OpenAI direto em outro fluxo)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Alertas Telegram (opcional)
# TELEGRAM_ENABLED=0
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_THREAD_ID=0
# TELEGRAM_MESSAGE_PREFIX=TYI
# TELEGRAM_TIMEOUT_SECONDS=8
# TELEGRAM_DEFAULT_MIN_INTERVAL_SECONDS=120
# Troca de preset com 1 linha:
# TELEGRAM_NOTIFY_PROFILE=prod   # baixo ruido (recomendado)
# TELEGRAM_NOTIFY_PROFILE=debug  # verboso (inclui starts/sucessos)
# Override manual opcional (se preenchido, ignora o profile):
# TELEGRAM_NOTIFY_EVENTS=job_failed,job_recovered,provider_circuit_open,provider_circuit_closed,provider_budget_exhausted,manual_scan_failed,health_degraded,health_recovered,admin_test,swing_trade_opened,swing_trade_updated,swing_trade_closed,swing_trade_failed

# Opcional
# BRAPI_BASE_URL=https://brapi.dev/api
