# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env (ele esta no .gitignore).

# Market data providers
MARKET_DATA_PROVIDERS=twelve_data,alpha_vantage,brapi,coingecko,google,yahoo
# Opcional: sobrescreve a lista para ativos BR/US/Cripto
# MARKET_DATA_PROVIDERS_BR=brapi,yahoo,google
# MARKET_DATA_PROVIDERS_US=twelve_data,alpha_vantage,yahoo
# MARKET_DATA_PROVIDERS_CRYPTO=coingecko,yahoo

# Tokens/keys (opcional, depende do provider habilitado)
BRAPI_TOKEN=
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=
COINGECKO_API_KEY=

# OpenClaw (LLM)
# Se seu plano da OpenAI não permite API, use OpenRouter:
OPENROUTER_API_KEY=

# (Opcional) caminhos de volumes no host (default do compose atual usa /srv/...)
# Para rodar em qualquer pasta, use o arquivo docker-compose.portable.yml
# ou sete explicitamente:
APP_VOL_DIR=./app_vol
OPENCLAW_CONFIG_DIR=./openclaw/config
OPENCLAW_WORKSPACE_DIR=./openclaw/workspace

# Opcional (se você usar OpenAI direto)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Opcional
# BRAPI_BASE_URL=https://brapi.dev/api
