# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env (ele esta no .gitignore).

# Market data providers
MARKET_DATA_PROVIDERS=twelve_data,alpha_vantage,brapi,coingecko,google,yahoo
# Opcional: sobrescreve a lista para ativos BR/US/Cripto
# MARKET_DATA_PROVIDERS_BR=market_scanner,brapi,yahoo,google
# MARKET_DATA_PROVIDERS_US=twelve_data,alpha_vantage,yahoo
# MARKET_DATA_PROVIDERS_CRYPTO=coingecko,yahoo
# Prioriza dados BR vindos do banco do market-scanner antes de chamar BRAPI/Yahoo.
# MARKET_DATA_USE_SCANNER_BR=1
# TTL do cache local para leitura do banco do scanner (segundos).
# MARKET_SCANNER_DATA_TTL_SECONDS=120
# Cache curto de quote do BRAPI (segundos), para evitar bursts no mesmo ciclo.
# BRAPI_QUOTE_CACHE_TTL_SECONDS=120
# Se BRAPI retornar limite/erro temporario, pausa novas tentativas por alguns segundos.
# BRAPI_RATE_LIMIT_COOLDOWN_SECONDS=300
# Se a CoinGecko retornar 429/limite, pausa tentativas por alguns segundos.
# COINGECKO_RATE_LIMIT_COOLDOWN_SECONDS=900
# Controle do sincronizador de mercado em background.
# MARKET_SYNC_ENABLED=1
# MARKET_SYNC_INTERVAL_SECONDS=300
# MARKET_SYNC_SCOPE=all
# MARKET_SYNC_FORCE_LIVE_BR=0

# Tokens/keys (opcional, depende do provider habilitado)
BRAPI_TOKEN=
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=
COINGECKO_API_KEY=

# Token do Gateway do OpenClaw (necessario para o backend chamar /tools/invoke).
# Dica: ele tambem fica em openclaw/config/openclaw.json (gateway.auth.token).
OPENCLAW_GATEWAY_TOKEN=

# (Opcional) URL do gateway (padrao: https://openclaw-gateway:18789 dentro do compose)
OPENCLAW_GATEWAY_URL=

# (Opcional) imagem do OpenClaw usada por openclaw-gateway/openclaw-cli.
# Padrao no compose: ghcr.io/openclaw/openclaw:latest
OPENCLAW_IMAGE=

# Integracao com Market Scanner (servico opcional via profile "scanner")
MARKET_SCANNER_BASE_URL=http://market-scanner:8000
MARKET_SCANNER_TIMEOUT_SECONDS=8
MARKET_SCANNER_PORT=8089
MARKET_SCANNER_DATA_DIR=./market-scanner/data
# Caminho do DB do scanner dentro do container backend (para backup duplo).
MARKET_SCANNER_DATABASE_PATH=/scanner_data/market_scanner.db

# TTL do cache de enriquecimento exibido na pagina do ativo, em dias.
VITE_OPENCLAW_ENRICHMENT_STALE_DAYS=3

# (Opcional) caminhos de volumes no host (default do compose atual usa /srv/...)
# Para rodar em qualquer pasta, use o arquivo docker-compose.portable.yml
# ou sete explicitamente:
APP_VOL_DIR=./app_vol
OPENCLAW_CONFIG_DIR=./openclaw/config
OPENCLAW_WORKSPACE_DIR=./openclaw/workspace

# Opcional (se você usar OpenAI direto em outro fluxo)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Opcional
# BRAPI_BASE_URL=https://brapi.dev/api
